VITE_ZOHO_PROXY_BASE_URL=http://localhost:8787/api/zoho
VITE_MOTOCO_API_BASE_URL=/api/live

# Do not put private Zoho credentials in any VITE_ variable.
# On Netlify, add private Zoho credentials in Site configuration -> Environment variables
# with Functions access enabled.

MOTOCO_API_PORT=8790
MOTOCO_ALLOWED_ORIGIN=http://localhost:5173

ZOHO_PROXY_PORT=8787
ZOHO_ALLOWED_ORIGIN=http://localhost:5173

ZOHO_API_DOMAIN=https://www.zohoapis.com.au
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com.au
ZOHO_CRM_VERSION=v8
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_CRM_ACCESS_TOKEN=
ZOHO_BOOKS_ACCESS_TOKEN=
ZOHO_CRM_REFRESH_TOKEN=

# Zoho Books monthly account invoice creation.
# Required for live invoices: ZOHO_BOOKS_REFRESH_TOKEN and ZOHO_BOOKS_ORGANIZATION_ID.
# The Books token must include item read access so invoice lines can auto-match by SKU.
# The CRM token is also used during invoice runs to skip already-invoiced Deals and mark linked Deals as Invoiced only after Books succeeds.
# Invoice rates are GST-inclusive. Optional: ZOHO_BOOKS_GST_TAX_ID only if Books needs a specific GST tax code attached to each line.
# Customer matching is strict by default: explicit Books customer id, exact business name match, exact email match, or create-new-customer if enabled.
# Optional: ZOHO_BOOKS_CREATE_CUSTOMERS=true lets the function create a Books Customer for the CRM Account/business when no existing customer is found.
# Optional but not recommended: ZOHO_BOOKS_ALLOW_LOOSE_CUSTOMER_MATCH=true allows one single search result to be treated as a match.
# Temporary testing only: ZOHO_BOOKS_ALLOW_FALLBACK_CUSTOMER=true plus ZOHO_BOOKS_FALLBACK_CUSTOMER_ID lets invoices use one fallback customer.
ZOHO_BOOKS_REFRESH_TOKEN=
ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_BOOKS_GST_TAX_ID=
ZOHO_BOOKS_CREATE_CUSTOMERS=false
ZOHO_BOOKS_ALLOW_LOOSE_CUSTOMER_MATCH=false
ZOHO_BOOKS_ALLOW_FALLBACK_CUSTOMER=false
ZOHO_BOOKS_FALLBACK_CUSTOMER_ID=

# Optional Zoho Books item id overrides. Normally the app finds these by SKU:
# MCO-COU-01, MCO-COU-02, MCO-COU-03, MCO-COU-04, MCO-COU-05.
ZOHO_BOOKS_ITEM_TYRE_1_BUNDLE_ID=
ZOHO_BOOKS_ITEM_TYRE_2_BUNDLE_ID=
ZOHO_BOOKS_ITEM_TYRE_3_PLUS_BUNDLE_ID=
ZOHO_BOOKS_ITEM_UP_TO_5KG_ID=
ZOHO_BOOKS_ITEM_5_TO_10KG_ID=
ZOHO_BOOKS_ITEM_10KG_PLUS_ID=
ZOHO_BOOKS_ITEM_RETURNS_ID=
ZOHO_BOOKS_RETURNS_SKU=

# Legacy fallback only. Used if an old delivery has no tyre/parts/returns detail.
ZOHO_BOOKS_SERVICE_ITEM_ID=
ZOHO_BOOKS_SERVICE_ITEM_SKU=

LOGIN_EMAIL_FROM=
ZEPTO_MAIL_TOKEN=
SESSION_SECRET=

ZOHO_CREATOR_OWNER=
ZOHO_CREATOR_APP=
ZOHO_ENVIRONMENT=

ZOHO_FORM_CUSTOMERS=Customers
ZOHO_FORM_DRIVERS=Drivers
ZOHO_FORM_JOBS=Delivery_Jobs
ZOHO_FORM_STATUS_HISTORY=Status_History

ZOHO_REPORT_CUSTOMERS=All_Customers_Report
ZOHO_REPORT_DRIVERS=All_Drivers_Report
ZOHO_REPORT_JOBS=All_Jobs_Management_Report
